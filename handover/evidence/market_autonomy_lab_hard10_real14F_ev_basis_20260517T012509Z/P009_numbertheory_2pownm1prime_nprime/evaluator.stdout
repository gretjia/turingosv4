ive (by norm_num : 1 < 2)\n    exact this\n  have : n = 1 := this\n  have : 2^1 - 1 = 1 := by norm_num\n  have h' : 2^n - 1 = 1 := h\n  rw [this] at h'\n  norm_num at h'\n  -- Actually simpler: from 2^n = 2 we get n=1, then 2^1-1=1, but h₁ says prime, 1 not prime\n  have : 2^1 - 1 = 1 := by norm_num\n  have : 2^n - 1 = 1 := h\n  rw [this] at this\n  -- Let's use a direct approach\n  have hpow : 2^n = 2 := by omega\n  have hn : n = 1 := by\n    apply Nat.eq_of_pow_eq_pow (by norm_num : 1 < 2) hpow\n    exact Nat.one_le_two_pow _\n  rw [hn] at h₁\n  have : ¬ Nat.Prime 1 := by norm_num\n  exact this h₁","gp_path":"per_tactic","gp_proof_file":"proofs/numbertheory_2pownm1prime_nprime_1778981774_66c85c98.lean"}
