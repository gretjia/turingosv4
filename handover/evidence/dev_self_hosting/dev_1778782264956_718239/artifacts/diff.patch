+    cas: &CasStore,
+    cid: &Cid,
+) -> Result<RoleAssignmentManifest, CasError> {
+    let bytes = cas.get(cid)?;
+    serde_json::from_slice(&bytes)
+        .map_err(|e| CasError::BackendCorruption(format!("role manifest decode: {e}")))
+}
