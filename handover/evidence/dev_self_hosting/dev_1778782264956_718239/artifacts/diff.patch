+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum VetoVerdict {
+    Accept,
+    Reject,
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
+pub enum VetoReasonClass {
+    CanaryEligible,
+    UnsafeMutation,
+    InsufficientEvidence,
+}
