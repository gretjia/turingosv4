+fn real5_write_prompt_capsule_v2_for_view(
+    cas_store: &mut turingosv4::bottom_white::cas::store::CasStore,
+    agent_id: &str,
+    assigned_role: turingosv4::runtime::real5_roles::AgentRole,
+    prompt_ctx_hash: turingosv4::state::q_state::Hash,
+    role_view: &turingosv4::runtime::real5_roles::DerivedView,
+    visible_context_bytes: &[u8],
+    role_view_bytes: &[u8],
+    path_label: &str,
+    logical_t: u64,
+) -> Result<turingosv4::bottom_white::cas::schema::Cid, String> {
+    use turingosv4::bottom_white::cas::schema::ObjectType;
+    use turingosv4::runtime::prompt_capsule::{write_prompt_capsule_v2_to_cas, PromptCapsuleV2};
+    use turingosv4::state::q_state::{AgentId, Hash};
+
+    let visible_context_cid = cas_store
+        .put(
+            visible_context_bytes,
+            ObjectType::Generic,
+            &format!("real5-{}-prompt-visible-context", path_label),
+            logical_t,
+            Some("real5.prompt.visible_context.v1".to_string()),
+        )
+        .map_err(|e| format!("PromptCapsuleV2 visible_context CAS put: {e}"))?;
+    let expected_prompt_context_hash =
+        turingosv4::bottom_white::cas::schema::Cid::from_content(visible_context_bytes);
+    if turingosv4::state::q_state::Hash(expected_prompt_context_hash.0) != prompt_ctx_hash {
+        return Err(format!(
+            "PromptCapsuleV2 prompt_context_hash mismatch: expected={} actual={:?}",
+            expected_prompt_context_hash, prompt_ctx_hash
+        ));
+    }
+    let role_view_cid = cas_store
+        .put(
+            role_view_bytes,
+            ObjectType::Generic,
+            &format!("real5-{}-derived-view", path_label),
+            logical_t,
+            Some("real5.derived_view.v1".to_string()),
+        )
+        .map_err(|e| format!("PromptCapsuleV2 role_view CAS put: {e}"))?;
+    if role_view_cid != role_view.visible_context_cid {
+        return Err(format!(
+            "PromptCapsuleV2 role_view CID mismatch: derived={} stored={}",
+            role_view.visible_context_cid, role_view_cid
+        ));
+    }
+    let mut read_set = role_view.read_set.clone();
+    if !read_set.contains(&role_view_cid) {
+        read_set.push(role_view_cid);
+    }
+    let role_label = assigned_role.label();
+    let prompt_capsule = PromptCapsuleV2 {
+        prompt_context_hash: prompt_ctx_hash,
+        agent_id: AgentId(agent_id.to_string()),
+        role: assigned_role,
+        view_policy_id: format!("real5/{}_view/v1", role_label.to_ascii_lowercase()),
+        visible_context_cid,
+        read_set,
+        hidden_fields_redacted: vec![
+            "raw prompt body".into(),
+            "raw completion".into(),
+            "private CoT".into(),
+        ],
+        system_prompt_template_hash: Hash(
+            turingosv4::bottom_white::cas::schema::Cid::from_content(
+                b"minif2f_v4::sdk::prompt::build_agent_prompt:v1",
+            )
+            .0,
+        ),
+        model_assignment_cid: None,
+    };
+    write_prompt_capsule_v2_to_cas(
+        cas_store,
+        &prompt_capsule,
+        &format!("real5-{}-prompt-capsule-v2", path_label),
+        logical_t,
+    )
+    .map_err(|e| format!("PromptCapsuleV2 CAS write: {e}"))
+}
