+    let bytes = serde_json::to_vec(guard)
+        .map_err(|e| CasError::BackendCorruption(format!("g7 guard encode: {e}")))?;
+    cas.put(
+        &bytes,
+        ObjectType::Generic,
+        &format!("real7-structural-guard-{suffix}"),
+        logical_t,
+        Some(G7_STRUCTURAL_GUARD_SCHEMA_ID.to_string()),
+    )
+}
