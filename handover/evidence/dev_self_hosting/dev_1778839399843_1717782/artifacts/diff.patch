+fn real5_role_for_attempt(
+    agent_idx: usize,
+) -> Result<turingosv4::runtime::real5_roles::AgentRole, String> {
+    let raw = std::env::var("TURINGOS_REAL5_ROLE_ASSIGNMENT").unwrap_or_default();
+    if raw.trim().is_empty() {
+        return Ok(turingosv4::runtime::real5_roles::AgentRole::Observer);
+    }
+    let parts: Vec<&str> = raw.split(',').map(str::trim).collect();
+    let role = parts
+        .get(agent_idx)
+        .ok_or_else(|| {
+            format!("TURINGOS_REAL5_ROLE_ASSIGNMENT missing role for agent_idx={agent_idx}")
+        })?
+        .parse::<turingosv4::runtime::real5_roles::AgentRole>()?;
+    Ok(role)
+}
+
+fn real5_derive_prompt_view(
+    agent_idx: usize,
+    agent_id: &str,
+    run_id: &str,
+    head_t: &str,
+) -> Result<(turingosv4::runtime::real5_roles::DerivedView, Vec<u8>), String> {
+    let assigned_role = real5_role_for_attempt(agent_idx)?;
+    real5_derive_prompt_view_for_role(assigned_role, agent_id, run_id, head_t)
+}
+
+fn real5_derive_prompt_view_for_role(
+    assigned_role: turingosv4::runtime::real5_roles::AgentRole,
+    agent_id: &str,
+    run_id: &str,
+    head_t: &str,
+) -> Result<(turingosv4::runtime::real5_roles::DerivedView, Vec<u8>), String> {
+    turingosv4::runtime::real5_roles::derive_role_view_with_context_bytes(
+        turingosv4::runtime::real5_roles::DerivedViewRequest {
+            agent_id: turingosv4::state::q_state::AgentId(agent_id.to_string()),
+            role: assigned_role,
+            task_id: turingosv4::state::q_state::TaskId(format!("task-{run_id}")),
+            head_t: head_t.to_string(),
+        },
+        turingosv4::runtime::real5_roles::DerivedViewInput {
+            read_set: Vec::new(),
+            price_signals: Vec::new(),
+            local_errors: Vec::new(),
+        },
+    )
+}
+
+fn real5_prompt_view_block(
+    view: &turingosv4::runtime::real5_roles::DerivedView,
+    role: turingosv4::runtime::real5_roles::AgentRole,
+) -> String {
+    if std::env::var("TURINGOS_REAL5_ROLE_VIEWS").unwrap_or_default() != "1" {
+        return String::new();
+    }
+    let sections = view.public_sections.join(", ");
+    let redacted = view.hidden_fields_redacted.join(", ");
+    format!(
+        "\n=== REAL-5 Role View ===\nrole: {}\nvisible_context_cid: {}\nview_policy_id: real5/{}_view/v1\npublic_sections: {}\nprice_signal_count: {}\nhidden_fields_redacted: {}\n",
+        role.label(),
+        view.visible_context_cid,
+        role.label().to_ascii_lowercase(),
+        sections,
+        view.price_signals.len(),
+        redacted
+    )
+}
