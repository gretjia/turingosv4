+fn real6d_scheduler_price_signals_from_q(
+    q: &turingosv4::state::q_state::QState,
+) -> Vec<turingosv4::runtime::real5_roles::PriceSignal> {
+    let mut signals = Vec::new();
+    for pool in q.economic_state_t.cpmm_pools_t.0.values() {
+        let total = pool.pool_yes.units.saturating_add(pool.pool_no.units);
+        let price = if total == 0 {
+            "None".to_string()
+        } else {
+            format!("{}/{}", pool.pool_yes.units, total)
+        };
+        signals.push(turingosv4::runtime::real5_roles::PriceSignal {
+            event_id: pool.event_id.0 .0.clone(),
+            price,
+            depth: i64::try_from(total).ok(),
+        });
+    }
+    signals
+}
