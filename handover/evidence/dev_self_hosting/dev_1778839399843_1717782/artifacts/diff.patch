+async fn real5_emit_role_gateway_rejection_to_l4e(
+    bus: &turingosv4::bus::TuringBus,
+    bundle: &turingosv4::runtime::ChaintapeBundle,
+    reg: &std::sync::Arc<
+        std::sync::Mutex<turingosv4::runtime::agent_keypairs::AgentKeypairRegistry>,
+    >,
+    args: Real5RoleGatewayRejectArgs<'_>,
+) -> Result<(), String> {
+    let mut cas_store = turingosv4::bottom_white::cas::store::CasStore::open(&bundle.cas_path)
+        .map_err(|e| format!("REAL-5 role gateway CAS open: {e}"))?;
