+            != Some(G7_STRUCTURAL_GUARD_SCHEMA_ID)
+        {
+            continue;
+        }
+        let Ok(bytes) = cas.get(&cid) else {
+            continue;
+        };
+        let Ok(guard) = serde_json::from_slice::<G7StructuralGuard>(&bytes) else {
+            continue;
+        };
+        if guard.schema_version == G7_STRUCTURAL_GUARD_SCHEMA_ID {
+            guards.push(guard);
+        }
+    }
