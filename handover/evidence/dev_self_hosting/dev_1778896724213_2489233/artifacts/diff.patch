+        "candidate weakness signals",
+        "challenge status",
+        "failed attempts",
+        "market depth",
+        "available balance",
+        "PnL",
+        "risk cap",
+    ] {
+        assert!(
+            bear_sections.contains(required),
+            "bear view missing {required}"
+        );
