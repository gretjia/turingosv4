+async fn real5_emit_role_gateway_rejection_to_l4e(
+    bus: &turingosv4::bus::TuringBus,
+    bundle: &turingosv4::runtime::ChaintapeBundle,
+    reg: &std::sync::Arc<
+        std::sync::Mutex<turingosv4::runtime::agent_keypairs::AgentKeypairRegistry>,
+    >,
+    args: Real5RoleGatewayRejectArgs<'_>,
+) -> Result<(), String> {
+    let mut cas_store = turingosv4::bottom_white::cas::store::CasStore::open(&bundle.cas_path)
+        .map_err(|e| format!("REAL-5 role gateway CAS open: {e}"))?;
+    let (outcome, error_class) = if args.parse_failed {
+        (
+            turingosv4::runtime::attempt_telemetry::AttemptOutcome::ParseFail,
+            Some(turingosv4::runtime::attempt_telemetry::LeanErrorClass::ParseFailed),
+        )
+    } else {
+        (
+            turingosv4::runtime::attempt_telemetry::AttemptOutcome::Aborted,
+            None,
+        )
+    };
+    let attempt_cid = r2_write_attempt_telemetry(
+        &mut cas_store,
+        R2AttemptArgs {
+            run_id: args.run_id,
+            agent_id: args.agent_id,
+            agent_idx: args.agent_idx,
+            proposal_count: args.attempt_seq,
+            prompt_ctx_hash: args.prompt_ctx_hash,
+            prompt_capsule_cid: args.prompt_capsule_cid,
+            prompt_visible_context_bytes: Some(args.prompt_visible_context_bytes),
+            prompt_tokens: args.prompt_tokens,
+            completion_tokens: args.completion_tokens,
+            candidate_bytes: args.public_summary.as_bytes(),
+            tool_name: args.path_label,
+            path_label: args.path_label,
+            is_omega_success: false,
+            outcome,
+            error_class,
+            lean_result: None,
+            verdict_kind: None,
+            model_name: args.model_name,
+            model_family: args.model_family,
+            model_provider: args.model_provider,
+            model_version: None,
+            temperature_milli: args.temperature_milli,
+            real5_role_view_head_t: args.real5_role_view_head_t,
+            logical_t: args.logical_t,
+        },
+    )?;
+    r3_emit_failure_path_worktx(
+        bus,
+        bundle,
+        reg,
+        args.run_id,
+        args.agent_id,
+        args.attempt_seq,
+        args.path_label,
+        attempt_cid,
+        args.logical_t,
+    )
+    .await
+}
