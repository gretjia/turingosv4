+    pub fn render_section_g_2(&self) -> String {
+        let mut out = String::new();
+        out.push_str("\n## §G.2 RiskCapImpactReport\n");
+        out.push_str("  (bankruptcy risk-cap admission rejections; derived from L4.E + CAS + replayed QState)\n");
