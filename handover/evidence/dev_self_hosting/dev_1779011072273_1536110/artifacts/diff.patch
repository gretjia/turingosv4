+// ─────────────────────────────────────────────────────────────────────
+// Arg parsing
+// ─────────────────────────────────────────────────────────────────────
+
+/// Result of subcommand-level arg parsing: either parsed args, or a help
+/// request that should print to stdout and exit 0.
+enum ParsedInit {
+    Args(InitArgs),
+    HelpRequested,
+}
+
+fn parse_init_args(args: &[String]) -> Result<ParsedInit, String> {
+    let mut project: Option<String> = None;
+    let mut template: Option<Template> = None;
+    let mut force = false;
+    let mut iter = args.iter();
+
+    while let Some(arg) = iter.next() {
+        match arg.as_str() {
+            "--project" => {
+                let val = iter
+                    .next()
+                    .ok_or_else(|| "missing value for --project".to_string())?;
+                project = Some(val.clone());
+            }
+            "--template" => {
+                let val = iter
+                    .next()
+                    .ok_or_else(|| "missing value for --template".to_string())?;
+                template = Some(Template::parse(val)?);
+            }
+            "--force" => {
+                force = true;
+            }
+            "-h" | "--help" => {
+                return Ok(ParsedInit::HelpRequested);
+            }
+            other => {
+                return Err(format!("unrecognized argument: {other}"));
+            }
+        }
+    }
+
+    let project =
+        project.ok_or_else(|| "missing required argument: --project <PATH>".to_string())?;
+    let template = template.unwrap_or(Template::Proof);
+
+    Ok(ParsedInit::Args(InitArgs {
+        project,
+        template,
+        force,
+    }))
+}
+
+// ─────────────────────────────────────────────────────────────────────
+// Helpers
+// ─────────────────────────────────────────────────────────────────────
+
+/// Shell-quote a path for safe display in a `cd <path>` hint.
+/// Uses single-quotes when the path contains whitespace or shell-special chars.
+/// Embedded single-quotes are escaped via `'\''`.
+fn shell_quote_path(path: &Path) -> String {
+    let raw = path.to_string_lossy();
+    let needs_quote = raw.is_empty()
+        || raw.chars().any(|c| {
+            c.is_whitespace()
+                || matches!(
+                    c,
+                    '"' | '\''
+                        | '$'
+                        | '`'
+                        | '\\'
+                        | '!'
+                        | '#'
+                        | '&'
+                        | '('
+                        | ')'
+                        | '*'
+                        | '<'
+                        | '>'
+                        | '?'
+                        | '['
+                        | ']'
+                        | '{'
+                        | '}'
+                        | '|'
+                        | ';'
+                )
+        });
+    if needs_quote {
+        format!("'{}'", raw.replace('\'', r"'\''"))
+    } else {
+        raw.to_string()
+    }
+}
+
+// ─────────────────────────────────────────────────────────────────────
+// init subcommand handler
+// ─────────────────────────────────────────────────────────────────────
+
+#[derive(Debug)]
+enum InitError {
+    /// Project path already exists as a regular file (not a directory).
+    ProjectIsFile(String),
+    /// Project directory already exists; `--force` not provided.
+    ProjectDirExists(String),
+    /// Filesystem I/O error.
+    Io(String),
+}
+
+impl InitError {
+    fn exit_code(&self) -> u8 {
+        match self {
+            // Domain errors (user intent conflict): exit 1
+            Self::ProjectIsFile(_) | Self::ProjectDirExists(_) => 1,
+            // Unexpected I/O: exit 2
+            Self::Io(_) => 2,
+        }
+    }
+}
+
+impl std::fmt::Display for InitError {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        match self {
+            Self::ProjectIsFile(p) => write!(
+                f,
+                "path exists but is a regular file (not a directory): {p} — pick a different --project path"
+            ),
+            Self::ProjectDirExists(p) => write!(
+                f,
+                "project directory already exists: {p} (use --force to overwrite the four scaffold files; other content is preserved)"
+            ),
+            Self::Io(msg) => write!(f, "io error: {msg}"),
+        }
+    }
+}
+
+fn cmd_init(args: InitArgs) -> Result<(), InitError> {
+    let project_dir = PathBuf::from(&args.project);
+
+    // Pre-flight classification: file vs directory vs absent.
+    if project_dir.exists() {
+        if project_dir.is_file() {
+            // Regular file at the path → never safe to scaffold over,
+            // not even with --force (we'd have to delete it).
+            return Err(InitError::ProjectIsFile(args.project.clone()));
+        }
+        if !args.force {
+            return Err(InitError::ProjectDirExists(args.project.clone()));
+        }
+    }
+
+    fs::create_dir_all(&project_dir)
+        .map_err(|e| InitError::Io(format!("create project dir {}: {e}", project_dir.display())))?;
+    fs::create_dir_all(project_dir.join("runtime_repo"))
+        .map_err(|e| InitError::Io(format!("create runtime_repo: {e}")))?;
+    fs::create_dir_all(project_dir.join("cas"))
+        .map_err(|e| InitError::Io(format!("create cas: {e}")))?;
+
+    let genesis_path = project_dir.join("genesis_payload.toml");
+    let agent_pubkeys_path = project_dir.join("agent_pubkeys.json");
+
+    fs::write(&genesis_path, args.template.content())
+        .map_err(|e| InitError::Io(format!("write genesis_payload.toml: {e}")))?;
+    fs::write(&agent_pubkeys_path, AGENT_PUBKEYS_PLACEHOLDER)
+        .map_err(|e| InitError::Io(format!("write agent_pubkeys.json: {e}")))?;
+
+    let cd_hint = shell_quote_path(&project_dir);
+
+    println!(
+        "Initialized TuringOS workspace at {} (template: {})",
+        project_dir.display(),
+        args.template.name(),
+    );
+    println!();
+    println!("Scaffold files created:");
+    println!("  {}", project_dir.join("runtime_repo").display());
+    println!("  {}", project_dir.join("cas").display());
+    println!("  {}", genesis_path.display());
+    println!("  {}", agent_pubkeys_path.display());
+    println!();
+    println!("Next steps (Phase 6.1+ subcommands; not yet implemented):");
+    println!("  cd {cd_hint}");
+    println!("  # Edit genesis_payload.toml and agent_pubkeys.json,");
+    println!("  # then: turingos agent deploy ... / turingos task open ...");
+    println!();
+    println!("Phase 6.0 baseline: use experiments/minif2f_v4/src/bin/lean_market.rs");
+    println!("for the established TB-10 workflow until later subcommands ship.");
+
+    Ok(())
+}
