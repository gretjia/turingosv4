+            error!("[real-bcast] role notification CAS write failed: {e}");
+            std::process::exit(3);
+        }
+    };
+    RealBcastTurnBundle {
+        digest_cid,
+        role_crop_cid,
+        epoch_id: format!("real-bcast:{run_id}:{agent_id}:{tx}"),
