+export PER_PROBLEM_TIMEOUT_S="${PER_PROBLEM_TIMEOUT_S:-300}"
+export TURINGOS_G_PHASE_DIRTY_OK="${TURINGOS_G_PHASE_DIRTY_OK:-1}"
