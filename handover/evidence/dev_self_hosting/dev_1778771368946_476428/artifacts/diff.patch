+            "{} role={} view_policy={} risk_budget_micro={}\n",
+            assignment.agent_id.0,
+            assignment.role.label(),
+            assignment.view_policy_id,
+            assignment.risk_budget_micro.micro_units()
+        ));
+    }
+    out
