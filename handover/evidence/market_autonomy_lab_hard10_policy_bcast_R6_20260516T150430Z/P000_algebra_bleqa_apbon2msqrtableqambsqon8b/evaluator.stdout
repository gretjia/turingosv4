_ = (x^2 + y^2)/2 - x*y := by\n        simp [Real.sqrt_mul (show 0 ≤ x^2 from by positivity), Real.sqrt_sq hxpos]\n      _ = ((x - y)^2)/2 := by ring\n  have hgoal : ((x - y)^2) / 2 ≤ (a - b)^2 / (8 * b) := by\n    rw [ha_eq, hb_eq]\n    have hpos_sq : 0 ≤ (x - y)^2 := by positivity\n    by_cases hzero : (x - y)^2 = 0\n    · simp [hzero]\n    · have hpos_denom : 0 < 8 * y^2 := by positivity\n      apply (div_le_div_right hpos_denom).mpr\n      field_simp\n      nlinarith\n  calc\n    (a + b) / 2 - Real.sqrt (a * b) = ((x - y)^2) / 2 := hcalc_eq\n    _ ≤ (a - b)^2 / (8 * b) := hgoal","gp_path":"per_tactic","gp_proof_file":"proofs/algebra_bleqa_apbon2msqrtableqambsqon8b_1778944080_c1a4bed4.lean"}
