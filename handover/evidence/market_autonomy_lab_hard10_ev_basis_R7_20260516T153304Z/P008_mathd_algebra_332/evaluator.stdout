    have : 0 ≤ Real.sqrt (x * y) := Real.sqrt_nonneg _\n    nlinarith\n  calc\n    x * y = (Real.sqrt (x * y))^2 := by\n      rw [Real.sq_sqrt hxynonneg]\n    _ = (Real.sqrt 19)^2 := by rw [h₁]\n    _ = 19 := by norm_num [Real.sq_sqrt (show 0 ≤ (19 : ℝ) from by norm_num)]","gp_path":"per_tactic","gp_proof_file":"proofs/mathd_algebra_332_1778946857_b32a481f.lean"}
